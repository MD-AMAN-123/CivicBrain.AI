{
  "functions": {
    "api/*": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/gemini",
      "destination": "/api/gemini.ts"
    },
    {
      "source": "/((?!api/|manifest.webmanifest|_vercel|assets/).*)",
      "destination": "/index.html"
    }
  ]
}